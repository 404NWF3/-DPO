# Claude detector (semantic detection layer). Optional - pipeline degrades to regex+keyword layers without it.
ANTHROPIC_API_KEY=
# Optional: custom gateway
ANTHROPIC_BASE_URL=
# Optional: model selection (default: claude-sonnet-4-6)
ANTHROPIC_MODEL=

# GLM OCR (image / scanned-PDF path). Optional - use --ocr-provider mock for testing.
ZHIPU_API_KEY=
# Optional: OCR endpoint. Default https://open.bigmodel.cn/api/paas/v4/files/ocr
# (multipart, line-level bbox). Endpoints containing "layout_parsing" use the
# JSON/base64 protocol instead.
GLM_OCR_ENDPOINT=
# Optional: files/ocr form fields (defaults: hand_write / CHN_ENG)
GLM_OCR_TOOL_TYPE=
GLM_OCR_LANGUAGE=
# Optional: layout_parsing model name (default: glm-ocr)
GLM_OCR_MODEL=
